# ===================================
# Unity .gitignore
# Arcane Shift: Lucky Brawlers
# ===================================

# ===================================
# Unity Generated Folders
# ===================================

# Library folder contains all imported assets, compiled scripts, etc.
# This is regenerated by Unity when opening the project
/[Ll]ibrary/

# Temp folder for Unity's temporary files during runtime
/[Tt]emp/

# Obj folder contains intermediate build files
/[Oo]bj/

# Build output folders
/[Bb]uild/
/[Bb]uilds/
/[Bb]uild[Oo]utput/

# WebGL specific build folders
/WebGL/
/WebGLBuild/
/WebGL[Bb]uilds/

# Windows/Mac/Linux standalone builds
/StandaloneBuild/
/WindowsBuild/
/MacBuild/
/LinuxBuild/

# Logs folder
/[Ll]ogs/

# Memory captures
/[Mm]emoryCaptures/

# Recording data
/[Rr]ecordings/

# Asset folder meta files regenerated by Unity
# (Keep the .meta files in Assets though!)

# ===================================
# Unity Cache & Auto-generated
# ===================================

# Unity asset store tools cache
/[Aa]sset[Ss]tore[Tt]ools/

# Autogenerated VS/MD/Rider solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files (outside Assets)
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ===================================
# Unity Collaborate & Cloud Build
# ===================================

/[Aa]ssets/[Aa]sset[Ss]tore[Tt]ools/
/Assets/Plugins/Editor/JetBrains*

# Unity Cloud Build
*.apk
*.aab
*.unitypackage
*.app

# Collaborate internal files
/Collaboration/

# ===================================
# IDE & Editor Specific
# ===================================

# Visual Studio
.vs/
*.vsconfig

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains Rider
.idea/
*.sln.iml

# MonoDevelop
*.pidb
*.unityproj

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# ===================================
# OS Generated Files
# ===================================

# macOS
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
Icon?

# macOS folder attributes
.fseventsd/

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Windows image file caches
*.stackdump

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ===================================
# Unity Packages & Dependencies
# ===================================

# NuGet packages (if using)
*.nupkg
packages/
!packages/manifest.json

# Node modules (if using WebGL tools)
node_modules/
npm-debug.log
yarn-error.log

# ===================================
# Unity Testing & Coverage
# ===================================

# Code coverage
/[Cc]ode[Cc]overage/
/CodeCoverage/
*.coverage
*.coveragexml

# Test results
TestResults/
/TestResults/
*.TestResults.xml

# ===================================
# Crashlytics & Analytics
# ===================================

crashlytics-build.properties
sysinfo.txt
crashlytics.properties

# Firebase (if using)
google-services.json
GoogleService-Info.plist

# ===================================
# Unity Services & Networking
# ===================================

# Unity Gaming Services local config (contains sensitive data)
# Keep the template, ignore actual config
# /Assets/StreamingAssets/UnityServicesConfig.json

# Relay/Lobby debug logs
relay-debug.log
lobby-debug.log

# ===================================
# Sensitive Files & Credentials
# ===================================

# API keys and secrets
*.secret
*.secrets
**/secrets/
*.key
*.pem
*.p12
*.pfx

# Environment files
.env
.env.local
.env.*.local
*.env

# Unity Cloud/Services credentials
/Assets/Resources/UnityServicesProjectConfiguration.asset

# ===================================
# Project Specific
# ===================================

# Local player preferences (dev testing)
/PlayerPrefs/

# Temporary test scenes
*_TEMP.unity
*_TEMP.unity.meta
*_TEST.unity
*_TEST.unity.meta
*_BACKUP.unity
*_BACKUP.unity.meta

# Screenshot/Recording folders (dev only)
/Screenshots/
/Recordings/
/Captures/

# Local documentation builds
/docs/_build/
/Documentation/html/

# Profiler data
*.data
*.raw
profiler-*.log

# ===================================
# Build Artifacts
# ===================================

# Compressed builds
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz

# Installer files
*.exe
*.msi
*.dmg
*.pkg

# Keep specific files if needed (uncomment)
# !ImportantBuild.zip

# ===================================
# WebGL Specific
# ===================================

# WebGL build cache
/WebGL/Build/
/WebGL/*.data
/WebGL/*.data.gz
/WebGL/*.data.br
/WebGL/*.wasm
/WebGL/*.wasm.gz
/WebGL/*.wasm.br
/WebGL/*.js
/WebGL/*.js.gz
/WebGL/*.js.br

# itch.io butler credentials
.butler/
butler-creds
.itch/

# ===================================
# Addressables & Asset Bundles
# ===================================

# Addressables build data (regenerated)
/Assets/AddressableAssetsData/*/*.bin
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/

# Asset bundles
/AssetBundles/
*.bundle
*.manifest

# Except the manifest file if you need versioning
# !AssetBundles/*.manifest

# ===================================
# Plastic SCM (Unity Version Control)
# ===================================

.plastic/
*.private
*.private.meta
/plastic4.selector

# ===================================
# Large Binary Files (use Git LFS instead)
# ===================================

# Uncomment if NOT using Git LFS for these
# *.psd
# *.tif
# *.tiff
# *.wav
# *.mp3
# *.ogg
# *.fbx
# *.blend
# *.obj
# *.max
# *.mb
# *.ma

# ===================================
# Backup Files
# ===================================

*.bak
*.backup
*.old
*.orig
*_backup*
*_old*
*_copy*
Copy of *
Backup of *

# ===================================
# Keep These Files (Exceptions)
# ===================================

# Keep the packages manifest
!Packages/manifest.json
!Packages/packages-lock.json

# Keep important project settings
!ProjectSettings/

# Keep the Assets folder structure
!Assets/

# Keep Git LFS tracking file
!.gitattributes

# ===================================
# End of .gitignore
# ===================================